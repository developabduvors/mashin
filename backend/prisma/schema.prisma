generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  fullName      String
  phone         String?
  role          Role           @default(BUYER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─── Catalog ────────────────────────────────────────────────

enum Condition {
  NEW
  USED
}

enum BodyType {
  SEDAN
  SUV
  HATCHBACK
  CROSSOVER
  MINIVAN
  COUPE
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
  GAS
}

enum Transmission {
  MT
  AT
  CVT
  ROBOT
}

model Brand {
  id      String     @id @default(uuid())
  name    String     @unique
  slug    String     @unique
  logoUrl String?
  models  CarModel[]
  cars    Car[]
}

model CarModel {
  id      String @id @default(uuid())
  name    String
  slug    String
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  cars    Car[]

  @@unique([brandId, slug])
}

model Car {
  id           String       @id @default(uuid())
  brandId      String
  modelId      String
  trim         String
  year         Int
  condition    Condition    @default(NEW)
  bodyType     BodyType
  fuelType     FuelType
  transmission Transmission
  price        Decimal      @db.Decimal(12, 2)
  monthlyFrom  Decimal?     @db.Decimal(12, 2)
  mileage      Int?
  hasPts       Boolean      @default(true)
  inStock      Boolean      @default(true)
  isFeatured   Boolean      @default(false)
  description  String?
  brand        Brand        @relation(fields: [brandId], references: [id])
  model        CarModel     @relation(fields: [modelId], references: [id])
  images       CarImage[]
  collections  CollectionCar[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([brandId])
  @@index([price])
  @@index([condition])
  @@index([bodyType])
}

model CarImage {
  id        String  @id @default(uuid())
  carId     String
  car       Car     @relation(fields: [carId], references: [id], onDelete: Cascade)
  url       String
  isCover   Boolean @default(false)
  sortOrder Int     @default(0)
}

// ─── CMS kontent ────────────────────────────────────────────

model PartnerBank {
  id        String  @id @default(uuid())
  name      String
  logoUrl   String
  isInsurer Boolean @default(false) // bank EMAS, sug'urta kompaniyasi
  sortOrder Int     @default(0)
}

model Review {
  id          String   @id @default(uuid())
  author      String
  text        String
  source      String? // qaysi platformadan (Yandex, 2GIS, ...)
  rating      Int?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([isPublished])
}

model ExternalRating {
  id               String  @id @default(uuid())
  platform         String // Yandex, Google, Otzovik
  rating           Decimal @db.Decimal(2, 1)
  recommendPercent Int?
  url              String?
}

model BlogPost {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  excerpt     String?
  body        String?
  coverUrl    String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([publishedAt])
}

model City {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  isDefault   Boolean      @default(false)
  dealerships Dealership[]
}

model Dealership {
  id       String   @id @default(uuid())
  cityId   String
  address  String
  phones   String[]
  schedule String?
  lat      Float?
  lng      Float?
  city     City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@index([cityId])
}

// ─── Credit Programs ────────────────────────────────────────

enum CreditKind {
  CREDIT
  INSTALLMENT // рассрочка
  TRADE_IN
  TAXI
  SPECIAL
}

model CreditProgram {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  kind        CreditKind @default(CREDIT)
  ratePercent Decimal?   @db.Decimal(5, 2)
  description String?
  imageUrl    String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)

  @@index([isActive])
}

// ─── Collections ────────────────────────────────────────────

model Collection {
  id        String          @id @default(uuid())
  title     String
  slug      String          @unique
  imageUrl  String?
  sortOrder Int             @default(0)
  cars      CollectionCar[]
}

// Many-to-many oraliq jadval (Car ↔ Collection).
model CollectionCar {
  collectionId String
  carId        String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  car          Car        @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@id([collectionId, carId])
}

// ─── Leads ──────────────────────────────────────────────────

enum LeadType {
  CREDIT_APPLICATION // avtokredit arizasi (kalkulyator)
  BEAT_OFFER         // "Перебьём предложения"
  CALLBACK           // "Получить выгоду/предложение"
  CAR_INQUIRY        // muayyan mashina bo'yicha so'rov
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  CONTACTED
  CONVERTED
  REJECTED
}

// 3 forma bitta modelga `type` bilan birlashadi. carId/brandId/modelId
// ataylab scalar (relation EMAS) — lead mashina o'chsa ham saqlanib qoladi.
model Lead {
  id           String     @id @default(uuid())
  type         LeadType
  status       LeadStatus @default(NEW)
  name         String?
  phone        String
  carId        String?
  brandId      String?
  modelId      String?
  trim         String?
  creditAmount Decimal?   @db.Decimal(12, 2)
  termMonths   Int?
  downPayment  Decimal?   @db.Decimal(12, 2)
  source       String?
  note         String?
  createdAt    DateTime   @default(now())

  @@index([status])
  @@index([type])
  @@index([createdAt])
}
